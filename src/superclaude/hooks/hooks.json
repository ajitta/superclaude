{
  "description": "SuperClaude hooks for session management and code formatting. Async hooks supported (v2.1.34+).",
  "schema_version": "2.1.37",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/session_init.py",
            "timeout": 10,
            "once": true
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/memory_staleness.py",
            "timeout": 5,
            "once": true
          }
        ]
      },
      {
        "matcher": "clear|compact|startup",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/context_reset.py",
            "timeout": 5
          },
          {
            "_comment": "[superclaude] notify if pending insights from prior session",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/insight_writer.py pending-count",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "_comment": "[superclaude] harvest INSIGHT: markers from transcript before compaction",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/insight_writer.py harvest-from-hook",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "_comment": "[superclaude] harvest INSIGHT: markers on /clear, /exit, logout",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/insight_writer.py harvest-from-hook",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/context_loader.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "_comment": "[superclaude] safety — blocks Read on files >30KB for token conservation",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/file_size_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "_comment": "[superclaude] safety — blocks destructive shell commands (Python; stdlib-only, no jq/grep/head dependency)",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/destructive_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "_comment": "[superclaude] safety — circuit breaker (SUPERCLAUDE_LOOP_GUARD=0 to disable)",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/loop_guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/prettier_hook.py",
            "timeout": 30
          },
          {
            "_comment": "[superclaude] optional — set SUPERCLAUDE_AUTO_TEST=0 to disable",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/test_runner_hook.py",
            "async": true,
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "_comment": "[superclaude] safety — circuit breaker records error/success signatures",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{SCRIPTS_PATH}}/loop_guard.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
