{
  "description": "SuperClaude hooks for session management and code formatting. Async hooks supported (v2.1.34+).",
  "schema_version": "2.1.37",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{SCRIPTS_PATH}}/session_init.py",
            "timeout": 10,
            "once": true
          }
        ]
      },
      {
        "matcher": "clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{SCRIPTS_PATH}}/context_reset.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{SCRIPTS_PATH}}/skill_activator.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 {{SCRIPTS_PATH}}/context_loader.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "_comment": "[superclaude] safety — blocks destructive shell commands",
            "type": "command",
            "command": "jq -r '.tool_input.command // empty' | head -1 | grep -qE 'rm\\s+-rf\\s+/\\s*$|rm\\s+-rf\\s+/\\*|git\\s+push\\s+.*--force.*(main|master)' && echo 'BLOCKED: destructive command detected' >&2 && exit 2 || exit 0",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{SCRIPTS_PATH}}/prettier_hook.py",
            "timeout": 30
          },
          {
            "_comment": "[superclaude] optional — set SUPERCLAUDE_AUTO_TEST=0 to disable",
            "type": "command",
            "command": "python3 {{SCRIPTS_PATH}}/test_runner_hook.py",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ]
  }
}
