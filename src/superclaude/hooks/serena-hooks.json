{
  "description": "Serena MCP recommended hooks. Authored by SuperClaude per upstream guidance (oraios.github.io/serena/02-usage/030_clients.html#claude-code). Serena does NOT ship hook payloads — these are SC-managed copies of the upstream recommendation. Installed only when Serena MCP is registered.",
  "_meta": {
    "source": "serena-recommended",
    "snapshot": "2026-04-27",
    "upstream_url": "https://oraios.github.io/serena/02-usage/030_clients.html#claude-code"
  },
  "hooks": {
    "PreToolUse": [
      {
        "_comment": "[superclaude] serena-recommended (snapshot 2026-04-27) — pre-tool reminder",
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks remind --client=claude-code"
          }
        ]
      },
      {
        "_comment": "[superclaude] serena-recommended (snapshot 2026-04-27) — auto-approve serena tool calls",
        "matcher": "mcp__serena__*",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks auto-approve --client=claude-code"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "_comment": "[superclaude] serena-recommended (snapshot 2026-04-27) — activate serena session",
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks activate --client=claude-code"
          }
        ]
      }
    ],
    "Stop": [
      {
        "_comment": "[superclaude] serena-recommended (snapshot 2026-04-27) — cleanup serena session",
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks cleanup --client=claude-code"
          }
        ]
      }
    ]
  }
}
